// =====================================================
// dbdiagram.io 임포트용 DBML
// 병원 진료기록 조회 시스템 (hospital-record-viewer)
// =====================================================
// 사용법: dbdiagram.io 접속 → 좌측 코드 영역에 전체 붙여넣기
// =====================================================

Table users {
  id         uuid        [pk, note: 'Supabase Auth 자동 생성']
  email      varchar(255) [unique, not null]
  created_at timestamptz [default: `now()`]

  note: 'Supabase Auth 관리 — 직접 수정 불가'
}

Table user_profiles {
  id                   uuid        [pk, default: `uuid_generate_v4()`]
  user_id              uuid        [unique, not null, ref: > users.id]
  role                 varchar(20) [not null, note: 'admin | doctor | patient']
  name                 varchar(100) [not null]
  must_change_password boolean     [default: false]
  is_active            boolean     [default: true]
  created_at           timestamptz [default: `now()`]
  updated_at           timestamptz [default: `now()`]
}

Table departments {
  id         uuid        [pk, default: `uuid_generate_v4()`]
  name       varchar(50) [unique, not null, note: '내과, 외과, 소아과 등']
  is_active  boolean     [default: true]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

Table examination_rooms {
  id            uuid        [pk, default: `uuid_generate_v4()`]
  department_id uuid        [not null, ref: > departments.id]
  room_number   varchar(20) [not null]
  is_active     boolean     [default: true]
  created_at    timestamptz [default: `now()`]
  updated_at    timestamptz [default: `now()`]

  indexes {
    (department_id, room_number) [unique]
  }
}

Table doctors {
  id             uuid        [pk, default: `uuid_generate_v4()`]
  user_id        uuid        [unique, not null, ref: > users.id]
  department_id  uuid        [not null, ref: > departments.id]
  license_number varchar(50) [not null]
  is_active      boolean     [default: true]
  created_at     timestamptz [default: `now()`]
  updated_at     timestamptz [default: `now()`]
}

Table patients {
  id         uuid        [pk, default: `uuid_generate_v4()`]
  user_id    uuid        [unique, not null, ref: > users.id]
  birth_date date        [not null]
  phone      varchar(20) [not null]
  is_active  boolean     [default: true]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

Table medical_records {
  id              uuid        [pk, default: `uuid_generate_v4()`]
  patient_id      uuid        [not null, ref: > patients.id]
  doctor_id       uuid        [not null, ref: > doctors.id]
  room_id         uuid        [not null, ref: > examination_rooms.id]
  visited_at      timestamptz [not null, note: '수정 불가']
  chief_complaint text
  diagnosis       text        [not null]
  prescription    text
  is_corrected    boolean     [default: false]
  correction_note text
  corrected_at    timestamptz
  created_at      timestamptz [default: `now()`]
  updated_at      timestamptz [default: `now()`]

  note: '삭제 불가. 오기입 시 is_corrected=true 후 새 기록 작성'
}

Table access_logs {
  id         uuid        [pk, default: `uuid_generate_v4()`]
  user_id    uuid        [not null, ref: > users.id]
  record_id  uuid        [ref: > medical_records.id, note: 'NULL = 목록 조회']
  action     varchar(20) [not null, note: 'view_list | view_detail']
  ip_address varchar(45)
  created_at timestamptz [default: `now()`]

  note: 'Append-only. 수정/삭제 불가'
}
